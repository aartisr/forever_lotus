{
  "name": "forever-lotus",
  "version": "1.0.0",
  "private": true,
  "description": "Forever Lotus: A civilizational call to conscious creation rooted in compassion, dignity, and planetary stewardship.",
  "author": "aartisr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aartisr/forever_lotus.git"
  },
  "keywords": [
    "conscious creation",
    "compassion",
    "dignity",
    "planetary stewardship",
    "humanitarian",
    "education",
    "peace",
    "buddhism",
    "hinduism",
    "philosophy"
  ],
  "engines": {
    "node": "20.x",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/ensure-no-next-dev.mjs && NEXT_IGNORE_INCORRECT_LOCKFILE=1 next build",
    "build:ci": "node scripts/ensure-no-next-dev.mjs && NEXT_IGNORE_INCORRECT_LOCKFILE=1 next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "perf:budgets": "node scripts/check-bundle-budgets.mjs"
  },
  "dependencies": {
    "framer-motion": "^11.3.0",
    "next": "^15.5.14",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.14",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "5.4.5",
    "vitest": "^4.1.2"
  }
}
